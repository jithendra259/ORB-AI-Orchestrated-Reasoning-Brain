{
  "name": "orb-ai",
  "displayName": "ORB AI",
  "description": "ORB AI - Orchestrated Reasoning Brain",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:orb-ai.repositoryView",
    "onCommand:orb-ai.scanRepository",
    "onCommand:orb-ai.showRepositoryGraph",
    "onCommand:orb-ai.analyzeCurrentFile",
    "onCommand:orb-ai.openPanel",
    "onCommand:orb-ai.openChat",
    "onStartupFinished",
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orb-ai",
          "title": "ORB AI",
          "icon": "resources/orb.svg"
        }
      ]
    },
    "views": {
      "orb-ai": [
        {
          "type": "webview",
          "id": "orb-ai.repositoryView",
          "name": "ORB AI"
        }
      ]
    },
    "commands": [
      {
        "command": "orb-ai.scanRepository",
        "title": "ORB AI: Scan Repository"
      },
      {
        "command": "orb-ai.showRepositoryGraph",
        "title": "ORB AI: Show Repository Graph"
      },
      {
        "command": "orb-ai.analyzeCurrentFile",
        "title": "ORB AI: Analyze Current File"
      },
      {
        "command": "orb-ai.openPanel",
        "title": "ORB AI: Open ORB AI Panel"
      },
      {
        "command": "orb-ai.openChat",
        "title": "ORB AI: Open Chat"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "orb-ai.scanRepository",
          "when": "view == orb-ai.repositoryView",
          "group": "navigation"
        },
        {
          "command": "orb-ai.showRepositoryGraph",
          "when": "view == orb-ai.repositoryView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production",
    "test-compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run test-compile && npm run lint"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
