{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch",
      "type": "npm",
      "script": "esbuild-watch",
      "isBackground": true,
      "presentation": {
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^([^(]+)\\((\\d+),(\\d+)\\): (error|warning|info) TS(\\d+): (.*)$",
          "file": 1,
          "location": 2,
          "message": 6
        }
      }
    }
  ],
  "inputs": []
}
